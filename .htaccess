RewriteEngine On

# Hide .php extension (Redirect external .php requests to extensionless url)
# Note: We exclude POST requests because a 301 redirect loses POST data.
RewriteCond %{THE_REQUEST} ^[A-Z]{3,}\s([^.]+)\.php [NC]
RewriteCond %{REQUEST_METHOD} !POST
RewriteRule ^ %1 [R=301,L]

# Resolve extensionless URLs to their .php files
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]
